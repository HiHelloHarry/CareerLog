{
  "name": "careerlog",
  "version": "0.1.0",
  "description": "업무 자동 감지 → 경력 기록 자동화",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "react:dev": "vite",
    "build": "vite build && electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "active-win": "^8.1.0",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.careerlog.app",
    "productName": "CareerLog",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    }
  }
}
